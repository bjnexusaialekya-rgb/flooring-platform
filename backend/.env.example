# Copy this file to .env and fill in real values. Never commit .env.

# Points at the Docker Postgres from docker-compose.yml (port 5434 —
# chosen deliberately to avoid colliding with enterprise-rag-postgres
# on 5433). Change if you installed Postgres natively instead.
DATABASE_URL=postgresql://flooring_admin:change_me_local_dev@localhost:5434/flooring_platform

# Any long random string — used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_real_random_secret

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Bound the Postgres pool (precaution checklist item)
PG_POOL_MAX=10

# --- Stripe (Phase 4 - not required until payments work begins) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Square (alternative to Stripe - client hasn't chosen yet) ---
SQUARE_ACCESS_TOKEN=replace_me
SQUARE_ENV=sandbox

# Which one is actually live. Flip this once the client decides —
# no code changes needed either way.
PAYMENT_PROVIDER=stripe

# --- QuickBooks Online ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QBO_REDIRECT_URI=http://localhost:4000/qbo/callback
# QBO_REALM_ID is intentionally NOT here anymore. The realm/company Id
# is resolved dynamically from qbo_tokens (whatever company an admin
# last connected via the OAuth flow) — see getActiveRealmId() in
# qboTokenManager.js. A static env var here was the actual bug that
# made sync silently fail after a successful "Connect to QuickBooks":
# nothing ever read it back out. Just connect via GET /qbo/connect-url
# and sync will work with no further config.
